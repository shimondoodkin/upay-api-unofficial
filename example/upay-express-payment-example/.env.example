# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
SESSION_SECRET=change-me

# Upay hosted payment form
UPAY_MERCHANT_EMAIL=helpmepro1@gmail.com
UPAY_REFERNAME=UPAY
UPAY_LIVE_SYSTEM=1
UPAY_DEFAULT_LANG=EN
UPAY_DEFAULT_CURRENCY=USD
UPAY_PAYMENT_URL=https://app.upay.co.il/API6/clientsecure/redirectpage.php

# Verification mode:
# mock = local/demo mode; marks paid only when using /dev/simulate-upay-return/:orderId
# api  = calls Upay server-to-server lookup. You must complete filters/credentials after confirming exact Upay API response.
UPAY_VERIFY_MODE=mock

# Upay API6 JSON endpoint for server-side lookup/refund/invoice actions
UPAY_API_URL=https://app.upay.co.il/API6/clientsecure/json.php
UPAY_API_USERNAME=
UPAY_API_KEY=

# Safe success rule. Use S only unless Upay confirms A is final for your account/payment type.
UPAY_PAID_STATUSES=S
